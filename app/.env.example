# Copia a .env (local) o configura estas variables en tu hosting.
# NUNCA subas .env con valores reales al repositorio.

# --- Programador en proceso (solo en instancia siempre activa) ---
ENABLE_SCHEDULER=1
SCHEDULER_TZ=Europe/Madrid

# --- Datos persistentes (carpeta con disco persistente en producción) ---
PATRIMONIO_DATA_DIR=/data

# --- WhatsApp GRATIS (CallMeBot) — opción recomendada ---
# Activa una vez desde tu móvil (ver FREE_SETUP.md) y pega aquí la API key.
CALLMEBOT_APIKEY=
CALLMEBOT_PHONE=34640253466
ALERT_THRESHOLD=10
# ALERT_SEND_EMPTY=1   # descomenta si quieres el aviso semanal aunque no haya subidas

# --- WhatsApp (Twilio) — alternativa; necesaria SOLO para recibir PDFs por WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=whatsapp:+34640253466

# --- Precios de skins por CSFloat (opcional; si no, usa Steam Market) ---
CSFLOAT_API_KEY=

# --- Seguridad del webhook entrante de WhatsApp (endpoint público) ---
# Si lo defines, el webhook exige ?token=ESTE_VALOR para aceptar peticiones.
WHATSAPP_WEBHOOK_TOKEN=
